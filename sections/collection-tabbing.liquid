<style>
  .tab-collcection{
    display: none;
  }
  .tab-collcection.tab-content-show {
    display: block;
  }
</style>
{%  if section.blocks.size > 0 %}
<div class="color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding">
  <div class="tabs-section page-container">
    {%  if section.settings.title != blank %}
      <div class="heading-navigation">
          <div class="section-heading text-center">
              <h2>{{ section.settings.title }}</h2>
          </div>
      </div>
    {%  endif  %}
    <div id="tabs" class="tabs">
      <div class="swiper-container tabs-slider tabs-slider-{{ section.id }}">
        <div class="swiper-wrapper">
          {%  for block in section.blocks %}
            {%  assign collection = collections[block.settings.collection] %}
            <div class="swiper-slide tab-list"><span class="tabs-category" id="tabs-{{ block.id }}">{{ collection.title | capitalize }}</span></div>
          {% endfor %}
        </div>
        <div class="swiper-button-prev tabs-navigation-prev swiper-button-prev-{{ section.id }}"></div>
        <div class="swiper-button-next tabs-navigation-next swiper-button-next-{{ section.id }}"></div>
      </div>
      {%  for block in section.blocks %}
        <div id="tabs-{{ block.id }}" class="tab-collcection">
          <div class="swiper swiper-slider-{{ block.id }}">
            <div class="swiper-wrapper">
              {%- for product in block.settings.collection.products limit: 12 -%}
                <div class="swiper-slide">
                  <div class="card-product-item">
                    {% render 'card-product',
                    product:product,
                    show-second-image: section.settings.show_secondary_image,
                    quick-add: section.settings.quick_add,
                    shop-now:section.settings.shop_now
                    %}
                  </div>
                </div>
              {% endfor %}
            </div>
            {% render 'slider-scroll-bar', block:block %}
          </div>
        </div>
      {% endfor %}
    </div>  
  </div> 
</div>
{%  endif %}  
<script name="Tabbing Collection Title Slider">
   var swiper = new Swiper(".tabs-slider-{{ section.id }}", {
    loop: false,
    allowTouchMove: true,
    slidesPerView: 'auto',
    spaceBetween: 0,
    mousewheel: true,
    slideToClickedSlide: true,
    centeredSlides: false,
    navigation: {
      nextEl: '.swiper-button-next-{{ section.id }}',
      prevEl: '.swiper-button-prev-{{ section.id }}',
    },
  });
</script>
{%  for block in section.blocks %}
{% render 'slider-js',block: block %}
{% endfor %}
<script>
document.addEventListener("DOMContentLoaded", function () {
  const tabSpans = document.querySelectorAll(".tab-list span");
  const tabContents = document.querySelectorAll(".tab-collcection");
  tabSpans.forEach(span => {
    span.addEventListener("click", function () {
      const tabId = span.id;      
      tabSpans.forEach(s => s.classList.remove("active"));
      span.classList.add("active");
      tabContents.forEach(content => content.classList.remove("tab-content-show"));
      const matchingContent = Array.from(tabContents).find(content => content.id === tabId);
      if (matchingContent) {
        matchingContent.classList.add("tab-content-show");
      }
    });
  }); 
  if (tabSpans[0]) tabSpans[0].click();
});

</script>
{% schema %}
  {
    "name": "Collection Tabbing",
    "tag": "section",
    "class": "section",
    "disabled_on": {
      "groups": ["header", "footer"]
    },
    "settings": [
      {
        "type": "text",
        "id": "title",
        "label": "Title"
      },
      {
        "type": "color_scheme",
        "id": "color_scheme",
        "label": "Color scheme",
        "default": "scheme-1"
      },
      {
        "type": "range",
        "id": "columns_show",
        "min": 1,
        "max": 6,
        "step": 0.1,
        "default": 4,
        "label": "t:sections.featured-collection.settings.columns_desktop.label"
      },
      {
        "type": "checkbox",
        "id": "show_secondary_image",
        "default": false,
        "label": "t:sections.featured-collection.settings.show_secondary_image.label"
      },
      {
        "type": "checkbox",
        "id": "quick_add",
        "default": true,
        "label": "t:sections.main-collection-product-grid.settings.quick_add.label"
      },
      {
        "type": "checkbox",
        "id": "shop_now",
        "default": false,
        "label": "Shop Now Button"
      },
      {
        "type": "checkbox",
        "id": "enable_wishlist",
        "label": "Enable Wishlist",
        "default": true
      }
    ],
    "blocks": [
    {
      "type": "tab",
      "name": "Tab",    
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        }
      ]
    }
  ],
    "presets": [
    {
      "name": "Collection Tabbing",
    }
  ]
  }
{% endschema %}
