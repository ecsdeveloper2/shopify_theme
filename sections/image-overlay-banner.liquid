<div class="image-overlay-section color-{{ section.settings.color_scheme }}">
  <div class="page-container-full">
    <div
      class="image-full-width"
      style="background-image: url({{ section.settings.banner_image | image_url }}); background-size: cover;background-position: top center;"
    >
      <div class="page-container">
        <div class="image-overlay-content">
          <p class="text-center">{{ section.settings.heading }}</p>
          <h2 class="text-center">{{ section.settings.description }}</h2>
          {% if section.settings.button_link and section.settings.button_text %}
            <a href="{{ section.settings.button_link }}" class="btn">{{ section.settings.button_text }}</a>
          {% endif %}
        </div>
      </div>
    </div>
  </div>
</div>
{% schema %}
{
  "name": "Image overlay Hero",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "banner_image",
      "label": "Banner Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "OUR INSPIRATION"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Modern fashion can be stylish and sustainable—looking good shouldn’t cost the planet."
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    }
  ],
  "presets": [
    {
      "name": "Image overlay Hero"
    }
  ]
}
{% endschema %}