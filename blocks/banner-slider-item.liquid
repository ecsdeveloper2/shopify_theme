<style>
  #shopify-block-{{ block.id }}:before {
      content: '';
      display: block;
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: rgb(0 0 0 / {{ block.settings.image_opacity }}%);
      z-index: 1;
  }
</style>
<div class="color-{{ block.settings.color_scheme }} banner-slider-block">
      {% if block.settings.image != blank %}
        <div class="slide-background-image desktop-image">
          {%- liquid
            assign height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio | round
            assign sizes = '100vw'
            assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
            assign fetch_priority = 'auto'
            if block.index == 1
              assign fetch_priority = 'high'
            endif
          -%}
          {{
            block.settings.image
            | image_url: width: 3840
            | image_tag: height: height, sizes: sizes, widths: widths, fetchpriority: fetch_priority
          }}
        </div>
      {% endif %}
      {% if block.settings['image-mobile'] != blank %}
        <div class="slide-background-image mobile-image">
          {%- liquid
            assign height = block.settings['image-mobile'].width | divided_by: block.settings['image-mobile'].aspect_ratio | round
            assign sizes = '100vw'
            assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
            assign fetch_priority = 'auto'
            if block.index == 1
              assign fetch_priority = 'high'
            endif
          -%}
          {{
            block.settings['image-mobile']
            | image_url: width: 3840
            | image_tag: height: height, sizes: sizes, widths: widths, fetchpriority: fetch_priority
          }}
        </div>
      {% endif %}

    <div class="page-container banner-slider-content-wrapper position-{{ block.settings.image_position }}">
      {% if block.settings.side_image != blank %}
        <div class="banner-side-image">
          {{ block.settings.side_image | image_url: width: 800 | image_tag: loading: 'lazy' }}
        </div>
      {% endif %}

      <div class="banner-content">
        {% if block.settings.heading != blank %}
          <h1>{{ block.settings.heading }}</h1>
        {% endif %}

        {% if block.settings.description != blank %}
          <p>{{ block.settings.description }}</p>
        {% endif %}

        {% if block.settings.button_text != blank %}
          <span class="btn">{{ block.settings.button_text }}</span>
        {% endif %}
      </div>
    </div>
</div>
{% schema %}
{
  "name": "Banner Slider item",
  "class": "banner-slider-item swiper-slide",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-1"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "image-mobile",
      "label": "Background Image (Mobile)"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Elevate Your Everyday Style"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Step into the latest trends and redefine your everyday look."
    },
    {
      "type": "range",
      "id": "image_opacity",
      "label": "Image Opacity",
      "min": 0,
      "max": 100,
      "step": 1,
      "default": 40,
      "unit": "%"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Link"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "image_picker",
      "id": "side_image",
      "label": "Side Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Side Image Position",
      "default": "right",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Banner Slider item"
    }
  ]
}
{% endschema %}