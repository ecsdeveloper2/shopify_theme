
<style>
    #shopify-block-{{ block.id }}:before {
        content: '';
        display: block;
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
        background-color: rgb(0 0 0 / {{ block.settings.image_opacity }}%);
        z-index: 1;
    }
</style>
<div class="color-{{ block.settings.color_scheme }} banner-slider-block">
    <a href="{{ block.settings.link }}" class="banner-slider-item-link" id="shopify-block-{{ block.id }}">
        {% if block.settings.image != blank or block.settings.image-mobile != blank %}
            {% if block.settings.image %}
                <div class="slide-background-image desktop-image">
                    {%- liquid
                    assign height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio | round
                        assign sizes = '100vw'
                        assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                    assign fetch_priority = 'auto'
                    if block.index == 1
                        assign fetch_priority = 'high'
                    endif
                    -%}
                    {{
                        block.settings.image
                        | image_url: width: 3840
                        | image_tag: height: height, sizes: sizes, widths: widths, fetchpriority: fetch_priority
                    }}
                </div>
            {% endif %}
            {% if block.settings.image-mobile %}
                <div class="slide-background-image mobile-image">
                    {%- liquid
                    assign height = block.settings.image-mobile.width | divided_by: block.settings.image-mobile.aspect_ratio | round
                        assign sizes = '100vw'
                        assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
                    assign fetch_priority = 'auto'
                    if block.index == 1
                        assign fetch_priority = 'high'
                    endif
                    -%}
                    {{
                        block.settings.image-mobile
                        | image_url: width: 3840
                        | image_tag: height: height, sizes: sizes, widths: widths, fetchpriority: fetch_priority
                    }}
                </div>
            {% endif %}
            {% else %}
             <div class="slide-background-image">
                {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
            </div>
        {% endif %}
    </a>
</div>
{% schema %}
{
    "name": "Banner Slider item",
    "class": "banner-slider-item swiper-slide",
    "settings": [
        {
            "type": "color_scheme",
            "id": "color_scheme",
            "label": "Color scheme",
            "default": "scheme-1"
        },
        {
            "type": "image_picker",
            "id": "image",
            "label": "Background Image"
        },
        {
            "type": "image_picker",
            "id": "image-mobile",
            "label": "Background Image (Mobile)"
        },
        {
            "type": "range",
            "id": "image_opacity",
            "label": "Image Opacity",
            "min": 0,
            "max": 100,
            "step": 1,
            "default": 40,
            "unit": "%"
        },
        {
            "type": "url",
            "id": "link",
            "label": "Link"
        }
    ],
    "presets": [
        {
            "name": "Banner Slider item"
        }
    ]
}
{% endschema %}