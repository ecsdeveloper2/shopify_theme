            <a href="{{ settings.social_instagram_link }}" class="link list-social__link d-flex">
                <span class="svg-wrapper">
                {{- 'icon-instagram.svg' | inline_asset_content -}}
                </span>
            </a>
        </li>
    {%- endif -%}
    {%- if settings.social_linkedin_link != blank -%}
        <li class="list-social__item">
            <a href="{{ settings.social_linkedin_link }}" class="link list-social__link d-flex">
                <span class="svg-wrapper">
                {{- 'icon-linkedin.svg' | inline_asset_content -}}
                </span>
            </a>
        </li>
    {%- endif -%}
    {%- if settings.social_pinterest_link != blank -%}
        <li class="list-social__item">
            <a href="{{ settings.social_pinterest_link }}" class="link list-social__link d-flex">
                <span class="svg-wrapper">
                {{- 'icon-pinterest.svg' | inline_asset_content -}}
                </span>
            </a>
        </li>
    {%- endif -%}
    {%- if settings.social_snapchat_link != blank -%}
        <li class="list-social__item">
            <a href="{{ settings.social_snapchat_link }}" class="link list-social__link d-flex">
                <span class="svg-wrapper">
                {{- 'icon-snapchat.svg' | inline_asset_content -}}
                </span>
            </a>
        </li>
    {%- endif -%}
    {%- if settings.social_youtube_link != blank -%}
        <li class="list-social__item">
            <a href="{{ settings.social_youtube_link }}" class="link list-social__link d-flex">
                <span class="svg-wrapper">
                {{- 'icon-youtube.svg' | inline_asset_content -}}
                </span>
            </a>
        </li>
    {%- endif -%}
</ul>