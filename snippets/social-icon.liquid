<ul class="list-unstyled list-social{% if class %} {{ class}}{% endif %} d-flex flex-wrap item-gap align-items-center" role="list">
    {%- if settings.social_facebook_link != blank -%}
        <li class="list-social__item">
            <a href="{{ settings.social_facebook_link }}" class="link list-social__link d-flex">
                <span class="svg-wrapper">
                {{- 'icon-facebook.svg' | inline_asset_content -}}
                </span>
            </a>
        </li>
    {%- endif -%}
    {%- if settings.social_twitter_link != blank -%}
        <li class="list-social__item">
            <a href="{{ settings.social_twitter_link }}" class="link list-social__link d-flex">
                <span class="svg-wrapper">
                {{- 'icon-twitter.svg' | inline_asset_content -}}
                </span>
            </a>
        </li>
    {%- endif -%}
    {%- if settings.social_instagram_link != blank -%}
