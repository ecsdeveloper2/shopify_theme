<div class="scrollbar-counter-navigation">
  <div class="swiper-scrollbar swiper-scrollbar-{% if block.id %}{{ block.id }}{% else %}{{ section.id }}{% endif %}"></div>
  <div class="counter-navigation">
    <div class="swiper-pagination swiper-pagination-{% if block.id %}{{ block.id }}{% else %}{{ section.id }}{% endif %} dark-text-white"></div>
    <div class="swiper-navigation">
      <div class="swiper-button-prev swiper-button-prev-{% if block.id %}{{ block.id }}{% else %}{{ section.id }}{% endif %}"></div>
      <div class="swiper-button-next swiper-button-next-{% if block.id %}{{ block.id }}{% else %}{{ section.id }}{% endif %}"></div>
    </div>
  </div>
</div>